# Frontend (Vite) env. Copy to .env.local for local dev (.env.local is gitignored).
# Only VITE_-prefixed vars reach the browser, and NONE of them are secrets:
# the LiveKit URL is public, and the API key/secret live ONLY on the server.

# LiveKit SFU websocket URL. Works unchanged against LiveKit Cloud or a Railway
# self-host — just point it at whichever you're running.
#   LiveKit Cloud:  wss://<your-project>.livekit.cloud
#   Self-host:      wss://your-livekit-host
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Token backend base URL (the server/ in this repo). Defaults to localhost in dev.
VITE_TOKEN_URL=https://localhost:8080
