# Copy to .env for local dev (real .env is gitignored — NEVER commit real keys).
# In production these are set in the Railway dashboard's Variables tab, not here.

# ── LiveKit ──────────────────────────────────────────────────────────────────
# The key + secret are SECRETS and live ONLY here / in Railway — never in the
# client. Works the same against LiveKit Cloud or a self-hosted LiveKit.
#   LiveKit Cloud → Settings → Keys gives you all three values.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=paste_your_livekit_api_key
LIVEKIT_API_SECRET=paste_your_livekit_api_secret

# How long minted tokens stay valid (LiveKit duration string). Optional.
LIVEKIT_TOKEN_TTL=2h

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowed browser origin(s), comma-separated. In dev this is your Vite server;
# in prod set it to your GitHub Pages origin.
#   e.g. https://localhost:5173,https://<you>.github.io
ALLOWED_ORIGIN=https://localhost:5173

# Local dev port only — Railway injects PORT automatically in production.
PORT=8080
